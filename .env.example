CANWXLAB_DATA_MODE=hybrid
CANWXLAB_ENABLE_LIVE_ECCC=true
CANWXLAB_ECCC_OGC_API_BASE=https://api.weather.gc.ca
CANWXLAB_ECCC_WMS_BASE=https://geo.weather.gc.ca/geomet
CANWXLAB_HTTP_TIMEOUT_SECONDS=10
CANWXLAB_HTTP_USER_AGENT="CanWxLab/0.1 (weather visualization; contact: ops@example.org)"
CANWXLAB_CACHE_TTL_SECONDS=300
CANWXLAB_ECCC_WMS_IMAGE_CACHE_TTL_SECONDS=600
CANWXLAB_ECCC_WMS_TIMED_IMAGE_CACHE_TTL_SECONDS=86400
CANWXLAB_CACHE_DIR=.canwxlab/cache

# Frontend (Vite) - basemap configuration
# Provide a vector style URL (PMTiles, OpenMapTiles, MapTiler, Stadia, etc.) for production.
# If unset, the app defaults to NASA GIBS Blue Marble instead of licensed commercial basemaps.
VITE_MAP_STYLE_URL=
# Optional explicit mode marker for telemetry / dev UI.
VITE_BASEMAP_MODE=fallback

# Simulation worker bridge: "stub" returns deterministic offline data; "cli" invokes canwxsim-cli.
CANWXLAB_SIMULATION_MODE=stub
