      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Dev: Web",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-web.ps1",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Dev: Full",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev.ps1",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Test: API",
      "type": "shell",
      "command": "services/api/.venv/Scripts/python.exe -m pytest services/api/tests -q",
